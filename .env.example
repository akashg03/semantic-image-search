# Copy this file to `.env` and fill in your values. Never commit `.env`.

# Required: from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Default number of paths printed by `search` when you omit `-k`
TOP_K=2

# Optional: override the multimodal embedding model (default: gemini-embedding-2-preview)
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
